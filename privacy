<title>Spot &amp; Futures — BULLION WIRE</title>
<style>
  :root{
    --ink:#0b0c0e; --panel:#17191d; --line:#2a2c31;
    --paper:#ede8dd; --paper-dim:#a9a496; --gold:#c9a227; --gold-bright:#e8c455;
    --bronze:#8c6b3f; --up:#5fbf7a; --down:#d9694f;
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  @import url('https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;0,6..72,700;1,6..72,500&family=IBM+Plex+Mono:wght@400;500;600&display=swap');
  body{background:var(--ink); color:var(--paper); font-family:'Newsreader', Georgia, serif; -webkit-font-smoothing:antialiased;}
  a{color:inherit; text-decoration:none;}
  .mono{font-family:'IBM Plex Mono', monospace;}

  .masthead{max-width:1240px; margin:0 auto; padding:24px 32px 18px; display:flex; align-items:flex-end; justify-content:space-between; border-bottom:2px solid var(--gold); flex-wrap:wrap; gap:16px;}
  .brand{display:flex; align-items:center; gap:14px;}
  .ingot{width:34px; height:27px; background:linear-gradient(135deg, var(--gold-bright), var(--bronze) 70%); clip-path:polygon(8% 0, 92% 0, 100% 100%, 0% 100%);}
  .brand h1{font-size:28px; font-weight:700; line-height:1;}
  .brand h1 em{font-style:normal; color:var(--gold);}
  nav{display:flex; gap:24px; font-family:'IBM Plex Mono', monospace; font-size:12px; letter-spacing:.06em; text-transform:uppercase; color:var(--paper-dim);}
  nav a:hover{color:var(--gold-bright);}

  .page-head{max-width:1240px; margin:0 auto; padding:40px 32px 20px; border-bottom:1px solid var(--line);}
  .eyebrow{font-family:'IBM Plex Mono', monospace; font-size:11px; letter-spacing:.14em; text-transform:uppercase; color:var(--gold); margin-bottom:10px;}
  .page-head h2{font-size:38px; font-weight:700;}
  .page-head p{color:#b9b3a4; font-size:15px; margin-top:10px; max-width:60ch;}

  .layout{max-width:1240px; margin:0 auto; padding:36px 32px 60px; display:grid; grid-template-columns:1fr 300px; gap:44px;}

  .list-item{display:grid; grid-template-columns:110px 1fr; gap:20px; padding:22px 0; border-bottom:1px solid var(--line);}
  .list-item .thumb{background:linear-gradient(135deg, var(--panel), var(--bronze) 180%); height:78px; border:1px solid var(--line);}
  .list-item .tag{font-family:'IBM Plex Mono', monospace; font-size:10px; letter-spacing:.1em; text-transform:uppercase; color:var(--gold); margin-bottom:8px;}
  .list-item h4{font-size:19px; font-weight:600; line-height:1.3; margin-bottom:8px;}
  .list-item h4:hover{color:var(--gold-bright);}
  .list-item p{font-size:14px; color:#b9b3a4; line-height:1.5; margin-bottom:8px;}
  .list-item .meta{font-family:'IBM Plex Mono', monospace; font-size:10.5px; color:var(--paper-dim);}

  .sidebar{}
  .side-panel{background:var(--panel); border:1px solid var(--line); border-top:2px solid var(--gold); padding:20px; margin-bottom:24px;}
  .side-panel h5{font-family:'IBM Plex Mono', monospace; font-size:11px; letter-spacing:.1em; text-transform:uppercase; color:var(--paper-dim); margin-bottom:14px;}
  .side-row{display:flex; justify-content:space-between; font-family:'IBM Plex Mono', monospace; font-size:12.5px; padding:8px 0; border-bottom:1px solid var(--line);}
  .side-row:last-child{border-bottom:none;}
  .side-row .up{color:var(--up);} .side-row .down{color:var(--down);}

  .pagination{display:flex; gap:8px; margin-top:30px; font-family:'IBM Plex Mono', monospace; font-size:12px;}
  .pagination a{border:1px solid var(--line); padding:8px 14px; color:var(--paper-dim);}
  .pagination a.active{background:var(--gold); color:var(--ink); border-color:var(--gold);}
  .pagination a:hover{border-color:var(--gold);}

  footer{border-top:1px solid var(--line); padding:30px 32px; max-width:1240px; margin:0 auto; display:flex; justify-content:space-between; flex-wrap:wrap; gap:14px; font-family:'IBM Plex Mono', monospace; font-size:11px; color:var(--paper-dim);}

  @media (max-width:900px){
    nav{display:none;}
    .layout{grid-template-columns:1fr;}
    .list-item{grid-template-columns:80px 1fr;}
  }
  :focus-visible{outline:2px solid var(--gold-bright); outline-offset:2px;}
</style>
</head>
